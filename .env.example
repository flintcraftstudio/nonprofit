PORT=8080

# Postmark (contact form emails)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=noreply@example.com
POSTMARK_TO=hello@example.com

# Tracking (omit to disable)
GTAG_ID=
PIXEL_ID=

# Cloudflare Turnstile (omit to disable)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Database
DB_PATH=./data/app.db

# "development" (default) or "production". Production requires a real
# SESSION_SECRET and trusts X-Forwarded-For from Caddy for rate limiting.
ENV=development

# Session/CSRF signing secret — must be >= 32 bytes in production.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
